{
  "name": "@zclaudia/plugin-sdk",
  "version": "0.1.0",
  "description": "Public contracts and development helpers for ZClaudia plugins.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./interactions": {
      "types": "./dist/interactions.d.ts",
      "import": "./dist/interactions.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": "./dist/runtime.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist coverage",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pack:check": "npm pack --dry-run",
    "check": "pnpm typecheck && pnpm test && pnpm build && pnpm pack:check",
    "prepublishOnly": "pnpm clean && pnpm typecheck && pnpm test && pnpm build"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "packageManager": "pnpm@9.15.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zclaudia/zclaudia-plugin-sdk.git"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
